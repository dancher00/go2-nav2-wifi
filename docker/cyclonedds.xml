<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain>
    <General>
      <Interfaces>
        <!-- Laptop Wi-Fi IP (huawei wlp2s0). Override: source /ws/scripts/setup-robot-wifi.sh -->
