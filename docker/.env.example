# Copy to .env and edit once: cp .env.example .env
GO2_AUTO_ENV=1
GO2_NET=wifi
GO2_ROBOT_IP=192.168.1.58
GO2_HOST_IP=192.168.1.90
# utlidar (default) or sport — must match how the map was built
# GO2_ODOM_SOURCE=sport
# cmd_vel TCP + sport bridge rate on robot (1–100 Hz, default 20)
# GO2_CMD_VEL_HZ=50
LIBGL_ALWAYS_SOFTWARE=1

# Cable instead of Wi-Fi:
# GO2_NET=eth
# GO2_ROBOT_IP=192.168.123.18
# GO2_HOST_IP=192.168.123.51
