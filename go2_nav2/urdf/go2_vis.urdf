<?xml version="1.0"?>
<!-- RViz only: link names must match TF (base_footprint, base_link, utlidar_lidar). -->
<robot name="go2_vis">
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.60 0.28 0.20"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 0.85"/>
      </material>
    </visual>
  </link>

  <joint name="footprint_to_base" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.30" rpy="0 0 0"/>
  </joint>

  <link name="utlidar_lidar">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.06" radius="0.04"/>
      </geometry>
      <material name="red">
        <color rgba="0.9 0.2 0.1 0.9"/>
      </material>
    </visual>
  </link>

  <joint name="base_to_lidar" type="fixed">
    <parent link="base_link"/>
    <child link="utlidar_lidar"/>
    <origin xyz="0.171 0 0.09" rpy="0 0 0"/>
  </joint>
</robot>
